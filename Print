def spacer(h=8):
    return Spacer(1, h)
 
def hr(color=None):
    return HRule(color=color or GRAY_LIGHT)
 
def label(text):
    return Paragraph(text.upper(), styles["section_label"])
 
def chnum(text):
    return Paragraph(text, styles["chapter_num"])
 
def title(text, style="page_title"):
    return Paragraph(text, styles[style])
 
def body(text):
    return Paragraph(text, styles["body"])
 
def italic(text):
    return Paragraph(text, styles["body_italic"])
 
def bullet(text, sub=None):
    items = [Paragraph(f"<bullet>&bull;</bullet>{text}", styles["bullet"])]
    if sub:
        items.append(Paragraph(sub, styles["sub_bullet"]))
    return items
 
def numbered(n, text, sub=None):
    items = [Paragraph(f"<b>{n}.</b>  {text}", styles["numbered"])]
    if sub:
        items.append(Paragraph(sub, styles["sub_bullet"]))
    return items
 
def pull_quote(text):
    return [
        HRule(color=AMBER, thickness=1.5),
        spacer(6),
        Paragraph(f'"{text}"', styles["pull_quote"]),
        spacer(6),
        HRule(color=AMBER, thickness=1.5),
        spacer(10),
    ]
 
def lesson_box(text):
    return ColorBox([
        Paragraph("LESSON", styles["callout_label"]),
        Paragraph(text, styles["callout_text"]),
    ], bg=TEAL_LIGHT, border_color=TEAL)
 
def action_box(items):
    rows = [Paragraph("WHAT TO DO", styles["callout_label_amber"])]
    for item in items:
        rows.append(Paragraph(f"\u2192  {item}", styles["callout_action"]))
    return ColorBox(rows, bg=AMBER_LIGHT, border_color=AMBER)
 
def warning_box(text):
    return ColorBox([
        Paragraph("NOTE", styles["callout_label_coral"]),
        Paragraph(text, ParagraphStyle("wb",
            fontName="PoppinsL", fontSize=9, leading=15,
            textColor=CORAL_TEXT)),
    ], bg=CORAL_LIGHT, border_color=CORAL)
 
def section_divider(text):
    return [
        spacer(16),
        HRule(color=GRAY_LIGHT),
        spacer(6),
        Paragraph(text.upper(), ParagraphStyle("div",
            fontName="Mono", fontSize=7, leading=10,
            textColor=GRAY_WARM, alignment=TA_CENTER)),
        spacer(6),
        HRule(color=GRAY_LIGHT),
        spacer(16),
    ]
 
 
def qs_card(header_color, header_text, title_text, steps):
    """Build a Quick Start card as a table."""
    content = []
    content.append(Paragraph(header_text.upper(), ParagraphStyle("qsh",
        fontName="Mono", fontSize=7, leading=11, textColor=header_color)))
    content.append(spacer(3))
    content.append(Paragraph(title_text, styles["qs_title"]))
    content.append(HRule(color=GRAY_LIGHT, thickness=0.5))
    content.append(spacer(4))
    for i, (step, sub) in enumerate(steps, 1):
        content.append(Paragraph(
            f'<font color="#0d6b5e"><b>{i}.</b></font>  {step}',
            styles["numbered"]))
        if sub:
            content.append(Paragraph(sub, styles["sub_bullet"]))
        content.append(spacer(3))
    return content
 
 
def term_row(name, definition):
    return [
        [
            Paragraph(name, styles["term_name"]),
            Paragraph(definition, styles["term_def"]),
        ]
    ]
 
 
def flag_card(letter, title_text, bullets):
    content = [
        Paragraph(letter, styles["flag_label"]),
        Paragraph(title_text, styles["flag_title"]),
    ]
    for b in bullets:
        content.append(Paragraph(f"\u00b7  {b}", ParagraphStyle("fb",
            fontName="PoppinsL", fontSize=8.5, leading=14,
            textColor=CHARCOAL_M, leftIndent=6, spaceAfter=1)))
    return content
 
 
