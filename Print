# ─── CUSTOM FLOWABLES ────────────────────────────────────
 
class ColorBox(Flowable):
    """A colored rounded rectangle for callouts."""
    def __init__(self, content_rows, bg, border_color, left_accent=True, width=None, radius=4):
        super().__init__()
        self.content_rows = content_rows  # list of Paragraphs
        self.bg = bg
        self.border_color = border_color
        self.left_accent = left_accent
        self._width = width or (W - ML - MR)
        self.radius = radius
        self.padding = 10
        self.spaceBefore = 8
        self.spaceAfter = 8
        self._height = None
 
    def wrap(self, availWidth, availHeight):
        inner_w = self._width - 2*self.padding - (3 if self.left_accent else 0)
        total_h = self.padding
        for p in self.content_rows:
            w, h = p.wrap(inner_w, availHeight)
            total_h += h + 3
        total_h += self.padding
        self._height = total_h
        return self._width, self._height
 
    def draw(self):
        c = self.canv
        w = self._width
        h = self._height
        r = self.radius
        # background
        c.setFillColor(self.bg)
        c.roundRect(0, 0, w, h, r, stroke=0, fill=1)
        # left accent bar
        if self.left_accent:
            c.setFillColor(self.border_color)
            c.rect(0, 0, 3, h, stroke=0, fill=1)
            # re-round the right side only by drawing bg on top-left
        # draw content
        x = self.padding + (3 if self.left_accent else 0)
        y = h - self.padding
        inner_w = w - 2*self.padding - (3 if self.left_accent else 0)
        for p in self.content_rows:
            pw, ph = p.wrap(inner_w, 9999)
            y -= ph
            p.drawOn(c, x, y)
            y -= 3
 
 
class HRule(Flowable):
    def __init__(self, color=None, thickness=0.5, width=None):
        super().__init__()
        self.color = color or GRAY_LIGHT
        self.thickness = thickness
        self._width = width
        self.spaceBefore = 10
        self.spaceAfter = 10
 
    def wrap(self, aw, ah):
        return (self._width or aw), self.thickness + 1
 
    def draw(self):
        self.canv.setStrokeColor(self.color)
        self.canv.setLineWidth(self.thickness)
        self.canv.line(0, 0, self._width or self.canv._pagesize[0]-ML-MR, 0)
 
 
class CoverPage(Flowable):
    def __init__(self):
        super().__init__()
        self.width, self.height = A4
 
    def wrap(self, aw, ah):
        return self.width, self.height
 
    def draw(self):
        c = self.canv
        w, h = self.width, self.height
 
        # Background
        c.setFillColor(TEAL)
        c.rect(0, 0, w, h, stroke=0, fill=1)
 
        # Subtle radial overlay effect (flat teal variant)
        c.setFillColor(colors.HexColor("#0a5a4f"))
        c.ellipse(w*0.05, h*0.3, w*0.55, h*0.85, stroke=0, fill=1)
        c.setFillColor(TEAL)
        c.ellipse(w*0.1, h*0.35, w*0.5, h*0.82, stroke=0, fill=1)
 
        # Top mono eyebrow
        c.setFont("Mono", 7.5)
        c.setFillColor(colors.HexColor("#ffffff55"))
        c.drawCentredString(w/2, h - 48*mm, "A LIVED-EXPERIENCE WORKBOOK")
 
        # DE (muted)
        c.setFont("Lora", 64)
        c.setFillColor(colors.HexColor("#ffffff35"))
        c.drawCentredString(w/2 - 68, h - 80*mm, "DE")
 
        # CULT (amber)
        c.setFont("Lora", 64)
        c.setFillColor(colors.HexColor("#f5a623"))
        c.drawCentredString(w/2 + 18, h - 80*mm, "CULT")
 
        # IVATE (white)
        c.setFont("Lora", 64)
        c.setFillColor(WHITE)
        c.drawCentredString(w/2 + 130, h - 80*mm, "IVATE")
 
        # Subtitle line
        c.setFont("Mono", 8)
        c.setFillColor(colors.HexColor("#ffffffaa"))
        c.drawCentredString(w/2, h - 95*mm, "ARE YOU IN ONE?")
 
        # Tagline
        c.setFont("LoraI", 12)
        c.setFillColor(colors.HexColor("#ffffffcc"))
        lines = [
            "Trapped in the shadows of control,",
            "individuals lose themselves to manipulation.",
            "Yet within every story of captivity lies",
            "the powerful potential for freedom."
        ]
        for i, line in enumerate(lines):
            c.drawCentredString(w/2, h - 112*mm - i*16, line)
 
        # Three pillars strip
        strip_y = h - 155*mm
        strip_h = 14*mm
        for i, label in enumerate(["SPOT IT", "LEAVE IT", "RECOVER"]):
            bx = w/2 - 55*mm + i*37*mm
            c.setFillColor(colors.HexColor("#00000044"))
            c.roundRect(bx, strip_y, 35*mm, strip_h, 2, stroke=0, fill=1)
            c.setFont("Mono", 7.5)
            c.setFillColor(colors.HexColor("#ffffffbb"))
            c.drawCentredString(bx + 17.5*mm, strip_y + 4.5*mm, label)
 
        # Bottom "THE WORKBOOK"
        c.setFont("PoppinsB", 11)
        c.setFillColor(WHITE)
        c.drawCentredString(w/2, 28*mm, "THE WORKBOOK")
 
        # Page rule
        c.setStrokeColor(colors.HexColor("#ffffff22"))
        c.setLineWidth(0.5)
        c.line(ML, 22*mm, w - MR, 22*mm)
 
 
# ─── PAGE TEMPLATE (header/footer) ───────────────────────
 
page_num = [0]
 
def on_page(canvas, doc):
    page_num[0] += 1
    pn = page_num[0]
    if pn <= 1:
        return  # skip cover
    canvas.saveState()
    canvas.setFont("Mono", 7)
    canvas.setFillColor(GRAY_WARM)
    # Footer: page number centered
    canvas.drawCentredString(W/2, 12*mm, f"— {pn - 1} —")
    # Header: workbook name
    canvas.drawString(ML, H - 12*mm, "DECULTIVATE  ·  THE WORKBOOK")
    canvas.drawRightString(W - MR, H - 12*mm, "decultivate.co")
    canvas.setStrokeColor(GRAY_LIGHT)
    canvas.setLineWidth(0.4)
    canvas.line(ML, H - 14*mm, W - MR, H - 14*mm)
    canvas.line(ML, 15*mm, W - MR, 15*mm)
    canvas.restoreState()
 
 
