class DecultivateDoc(BaseDocTemplate):
    def __init__(self, filename, **kw):
        super().__init__(filename, **kw)
        self._current_template = "cover"
        normal_frame = Frame(ML, MB + 8*mm, W-ML-MR, H-MT-MB-20*mm, id='normal')
        self.addPageTemplates([
            PageTemplate(id='cover', frames=[normal_frame], onPage=on_page_cover),
            PageTemplate(id='inner', frames=[normal_frame], onPage=on_page_inner),
            PageTemplate(id='closing', frames=[normal_frame], onPage=on_page_closing),
        ])
 
